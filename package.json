{
  "name": "ai-go",
  "version": "0.1.0",
  "private": true,
  "description": "AI 기반 실시간 음성 분석 및 말버릇 교정 서비스",
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "build": "bun --bun next build",
    "start": "bun --bun next start -p 3001",
    "lint": "eslint . --fix --cache --cache-location ./node_modules/.cache/eslint/.eslintcache",
    "lint:check": "eslint . --cache --cache-location ./node_modules/.cache/eslint/.eslintcache",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\" --cache --ignore-path .gitignore",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json}\" --cache --ignore-path .gitignore"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
